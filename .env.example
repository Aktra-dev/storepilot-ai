# --- General ---
APP_NAME=StorePilot AI
APP_ENV=development
DEBUG=True

# --- Database ---
# Untuk Supabase (PostgreSQL production):
# DATABASE_URL=postgresql://postgres:[PASSWORD]@[PROJECT].supabase.co:5432/postgres?sslmode=require
#
# Untuk local development (SQLite):
# DATABASE_URL=sqlite:///./storepilot.db
DATABASE_URL=postgresql://postgres:password@localhost:5432/storepilot

# --- Security ---
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- AI Provider ---
# fallback = rule-based only (no external AI call, always works, no key needed)
# anthropic = real Claude API calls (requires AI_API_KEY)
AI_PROVIDER=fallback
AI_API_KEY=
AI_MODEL=claude-sonnet-4-5-20250929

# --- CORS ---
CORS_ORIGINS=*
